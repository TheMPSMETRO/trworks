<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Platform - TradeWorks</title>
    <link rel="stylesheet" href="/mainpage/style.css">
    <link rel="stylesheet" href="/views/userspage/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">


    <link rel="stylesheet" href="/views/tradingpage/trading.css">
    

    <script>
        const deposited = JSON.parse(<%- JSON.stringify(deposited) %>)
        if(deposited){
            const inventory = JSON.parse(localStorage.getItem('inv'))
            let deparray = []
        
            deposited.forEach(item => {

                if(item.appid === 440){
                    const existingitem = inventory['Team Fortress 2'].filter(i => i.assetID === item.assetid)
                    deparray.push(...existingitem)
                }
                if(item.appid === 252490){
                    const existingitem = inventory['Rust'].filter(i => i.assetID === item.assetid)
                    deparray.push(...existingitem)
                }
                if(item.appid === 570){
                    const existingitem = inventory['Dota 2'].filter(i => i.assetID === item.assetid)
                    deparray.push(...existingitem)
                }
                if(item.appid === 730){
                    const existingitem = inventory['Counter-Strike 2'].filter(i => i.assetID === item.assetid)
                    deparray.push(...existingitem)
                }
            });

            console.log(deposited)
        }
        
    </script>
</head>
<body>
    <header>
        <div class="container">
            <nav class="navbar">
                <div class="logo">
                    <img src="https://community.akamai.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGIGz3UqlXOLrxM-vMGmW8VNxu5Dx60noTyLwiYbf_jdk4veqYaF7IfysCnWRxuF4j-B-Xxa_nBovp3Pdwtj9cC_GaAd0DZdwQu9fuhS4kNy0NePntVTbjYpCyyT_3CgY5i9j_a9cBkcCWUKV/360fx360f" alt="TradeWorks Logo" id="logo-img">
                    <span class="logo-text">TradeWorks</span>
                </div>
                <div class="nav-links">
                    <a href="/UserPersonal">Home</a>
                    <a href="#" class="active">Trade</a>
                    <a href="#">Rent</a>
                    <a href="#">Marketplace</a>
                    <a href="#">About</a>
                </div>
                
                <div class="balancedrop">
                    <div class="balance">
                        <p class="balanceitem">$<strong class="balancevalue">0.00</strong></p>
                        <p>TradeWorks balance</p>
                    </div>
                    <!-- User dropdown menu -->
                    <div class="user-dropdown">
                        <div class="user-profile" id="user-dropdown-trigger">
                            <img src="<%- ProfilePicture %>" alt="User Avatar" class="user-avatar">
                            <span class="user-nickname"><%- name %></span>
                            <span class="dropdown-arrow">▼</span>
                        </div>
                        <div class="dropdown-content" id="user-dropdown">
                            <a href="/profile" class="dropdown-item">
                                <span class="dropdown-icon"><i class="bi bi-person-fill"></i></span>
                                <span>Profile</span>
                            </a>
                            <a href="/settings" class="dropdown-item">
                                <span class="dropdown-icon"><i class="bi bi-gear"></i></span>
                                <span>Settings</span>
                            </a>
                            <div class="dropdown-divider"></div>
                            <a href="/logout" class="dropdown-item logout">
                                <span class="dropdown-icon"><i class="bi bi-box-arrow-right"></i></span>
                                <span>Log-Out</span>
                            </a>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="container">
        <h1 class="page-title">Trade with Other Users</h1>
        
        <div class="inventory">
            <div class="inventory-header">
                <h2 class="inventory-title">Your <span>Inventory</span></h2>
                <div class="inventory-filters">
                    <input type="text" class="inventory-search" placeholder="Search items...">
                    <select class="inventory-filter">
                        <option value="all">All Games</option>
                        <option value="cs2">CS2</option>
                        <option value="dota2">Dota 2</option>
                        <option value="tf2">Team Fortress 2</option>
                    </select>
                </div>
            </div>
            
            <div class="inventory-grid">
               
            </div>
        </div>
        <!-- Incoming Offers Section -->
        <div class="incoming-offers">
            <h2 class="section-title">Incoming <span>Trade Offers</span></h2>
            
            <div class="offers-container">
                <!-- Offer Filter Controls -->
                <div class="offers-filter">
                    <div class="filter-tabs">
                        <button class="filter-tab active" data-filter="all">Cash trades</button>
                        <button class="filter-tab" data-filter="pending">Item Trades</button>
                    </div>
                    <div class="offers-search">
                        <button class="sendtradebtn">
                            Send A Trade
                        </button>
                    </div>
                </div>
                
                <!-- Offers List -->
                <div class="offers-list">
                    <!-- Example Offer Item -->
                    <div class="offer-item pending">
                        <div class="offer-header">
                            <div class="offer-user">
                                <img src="https://community.fastly.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGJKz2lu_XsnXwtmkJjSU91dh8bj35VTqVBP4io_frHcVuPaoafU1JqiVWWSVkux15OQ8Giiylk0k5mvTnIqpd3PCaQIhWMYkE_lK7EcNeCKW-w/62fx62f" 
                                    alt="Trader" class="offer-avatar">
                                <div class="offer-user-info">
                                    <h4 class="offer-username">TradeBot</h4>
                                    <span class="offer-time">2 hours ago</span>
                                </div>
                            </div>
                            <div class="offer-status pending">Pending</div>
                        </div>
                        
                        <div class="offer-content">
                            <div class="offer-items">
                                <div class="offer-items-column">
                                    <h5>Your Items</h5>
                                    <div class="items-preview">
                                        <div class="item-preview">
                                            <img src="https://community.fastly.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGJKz2lu_XuWbwcuyMESA4Fdl-4nnpU7iQA3-kKnr8ytd6s27erd4M77AXWWWx7h3tOA5SyvilEkj5WuGw42qc3zEOg4iDJEjQu9b4xa6w4DgKaq8sDVgNcPY/62fx62f 1x, https://community.fastly.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGJKz2lu_XuWbwcuyMESA4Fdl-4nnpU7iQA3-kKnr8ytd6s27erd4M77AXWWWx7h3tOA5SyvilEkj5WuGw42qc3zEOg4iDJEjQu9b4xa6w4DgKaq8sDVgNcPY/62fx62fdpx2x 2x" 
                                                alt="Item" class="item-preview-img">
                                            <span class="item-preview-count">+2</span>
                                        </div>
                                    </div>
                                    <div class="offer-value">$125.00</div>
                                </div>
                                
                                <div class="offer-arrow">
                                    <i class="bi bi-arrow-left-right"></i>
                                </div>
                                
                                <div class="offer-items-column">
                                    <h5>Their Items</h5>
                                    <div class="items-preview">
                                        <div class="item-preview">
                                            <img src="https://community.fastly.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGJKz2lu_XuWbwcuyMESA4Fdl-4nnpU7iQA3-kKnr8ytd6s29Y6FhJeScACnDkL8j6LU8GS3mwUh24G-Bno2tIymeblMgC5R3F-ECsBK6k4XuN-Lh-UWA3P3GyEv9/62fx62f 1x, https://community.fastly.steamstatic.com/economy/image/i0CoZ81Ui0m-9KwlBY1L_18myuGuq1wfhWSaZgMttyVfPaERSR0Wqmu7LAocGJKz2lu_XuWbwcuyMESA4Fdl-4nnpU7iQA3-kKnr8ytd6s29Y6FhJeScACnDkL8j6LU8GS3mwUh24G-Bno2tIymeblMgC5R3F-ECsBK6k4XuN-Lh-UWA3P3GyEv9/62fx62fdpx2x 2x" 
                                                alt="Item" class="item-preview-img">
                                            <span class="item-preview-count">+1</span>
                                        </div>
                                    </div>
                                    <div class="offer-value">$130.50</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="offer-actions">
                            <button class="btn-offer accept">
                                <i class="bi bi-check-circle"></i> Accept
                            </button>
                            <button class="btn-offer decline">
                                <i class="bi bi-x-circle"></i> Decline
                            </button>
                            <button class="btn-offer view">
                                <i class="bi bi-eye"></i> View Details
                            </button>
                        </div>
                    </div>
                    
                    <!-- More offers would appear here -->
                    
                    <!-- Empty state -->
                    <div class="offers-empty">
                        <div class="empty-icon">
                            <i class="bi bi-envelope-open"></i>
                        </div>
                        <h3>No incoming offers</h3>
                        <p>When you receive trade offers, they'll appear here</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Trade Interface Section -->
        <div class="trade-interface">
            <h2 class="section-title">Instant <span>Sale</span></h2>
            
            <div class="trade-container">
                <!-- Your Items Column -->
                <div class="trade-column">
                    <div class="trade-column-header">
                        <h3>Your Items</h3>
                        <div class="trade-value">Total: $0.00</div>
                    </div>
                    <div class="trade-items-grid" id="your-items">
                        <!-- Your items will be populated by JavaScript -->
                    </div>
                </div>
                
                <!-- Trade Actions Column -->
                <div class="trade-actions-column">
                    <button class="btn-trade" id="confirm-trade" disabled>
                        <i class="bi bi-arrow-left-right"></i> Confirm Trade
                    </button>
                    <div class="trade-details">
                        <div class="trade-value-comparison">
                            <div>You Will Recieve: <span id="value-difference">$0.00</span></div>
                        </div>
                    </div>
                </div>
                
                <!-- Their Items Column -->
                <div class="trade-column">
                    <div class="trade-column-header">
                        <h3><span id="trader-name">Trader's</span> Items</h3>
                        <div class="trade-value">Total: $0.00</div>
                    </div>
                    <div class="trade-items-grid" id="their-items">
                        <!-- Their items will be populated by JavaScript -->
                    </div>
                </div>
            </div>
        </div>
        
    </div>
    <div class="activity">

    </div>




































        <!-- Trade Modal Structure -->
        <div class="trade-modal" id="tradeModal">
            <div class="trade-modal__overlay"></div>
            <div class="trade-modal__container">
                
                <!-- Step 1: User Search -->
                <div class="trade-modal__step trade-modal__step--search" data-step="1">
                <div class="trade-modal__header">
                    <h2 class="trade-modal__title">Find Trading Partner</h2>
                    <button class="trade-modal__close">&times;</button>
                </div>
                
                <div class="trade-modal__search">
                    <div class="trade-modal__search-bar">
                    <input type="text" class="trade-modal__search-input" placeholder="Search by username, SteamID...">
                    <button class="trade-modal__search-btn">
                        <i class="bi bi-search"></i>
                    </button>
                    </div>
                    
                    <div class="trade-modal__results">
                    <div class="trade-modal__empty-state">
                        <i class="bi bi-people-fill trade-modal__empty-icon"></i>
                        <p class="trade-modal__empty-text">Search for trading partners</p>
                    </div>
                    </div>
                </div>
                </div>
                
                <!-- Step 2: Trade Creation -->
                <div class="trade-modal__step trade-modal__step--trade" data-step="2">
                <div class="trade-modal__header">
                    <button class="trade-modal__back">
                    <i class="bi bi-arrow-left"></i>
                    </button>
                    <h2 class="trade-modal__title">Create Trade Offer</h2>
                    <button class="trade-modal__close">&times;</button>
                </div>
                
                <div class="trade-modal__trade-profiles">
                    <div class="trade-modal__profile-card">
                    <img src="<%- ProfilePicture %>" class="trade-modal__profile-avatar">
                    <div class="trade-modal__profile-info">
                        <h3 class="trade-modal__profile-name"><%- name %></h3>
                        <div class="trade-modal__profile-stats">
                        <span class="trade-modal__profile-badge trade-modal__profile-badge--trader">Trader</span>
                        <span class="trade-modal__profile-stat">42 trades</span>
                        <span class="trade-modal__profile-stat">$<span class="trade-modal__profile-balance">0.00</span></span>
                        </div>
                    </div>
                    </div>
                    
                    <div class="trade-modal__trade-arrow">
                    <i class="bi bi-arrow-left-right"></i>
                    </div>
                    
                    <div class="trade-modal__profile-card" id="theirProfileCard">
                    <!-- Their profile will be loaded here -->
                    </div>
                </div>
                
                <div class="trade-modal__inventory-container">
                    <div class="trade-modal__inventory">
                    <h3 class="trade-modal__inventory-title">Your Inventory</h3>
                    <div class="trade-modal__inventory-grid" id="yourInventoryGrid"></div>
                    </div>
                    
                    <div class="trade-modal__inventory">
                    <h3 class="trade-modal__inventory-title">Their Inventory</h3>
                    <div class="trade-modal__inventory-grid" id="theirInventoryGrid"></div>
                    </div>
                </div>
                
                <div class="trade-modal__trade-summary">
                    <h3 class="trade-modal__summary-title">Trade Summary</h3>
                    
                    <div class="trade-modal__trade-sides">
                    <div class="trade-modal__trade-side">
                        <h4 class="trade-modal__side-title">You Give</h4>
                        <div class="trade-modal__items-list" id="yourTradeItems"></div>
                        <div class="trade-modal__side-total">Total: $<span id="yourTradeTotal">0.00</span></div>
                    </div>
                    
                    <div class="trade-modal__trade-side">
                        <h4 class="trade-modal__side-title">You Receive</h4>
                        <div class="trade-modal__items-list" id="theirTradeItems"></div>
                        <div class="trade-modal__side-total">Total: $<span id="theirTradeTotal">0.00</span></div>
                    </div>
                    </div>
                    
                    <div class="trade-modal__trade-actions">
                    <button class="trade-modal__btn trade-modal__btn--cancel">Cancel</button>
                    <button class="trade-modal__btn trade-modal__btn--confirm" disabled>Confirm Trade</button>
                    </div>
                </div>
                </div>
                
                <!-- Cash Purchase Modal -->
                <div class="trade-modal__step trade-modal__step--purchase" data-step="purchase">
                <div class="trade-modal__header">
                    <button class="trade-modal__back">
                    <i class="bi bi-arrow-left"></i>
                    </button>
                    <h2 class="trade-modal__title">Purchase Item</h2>
                    <button class="trade-modal__close">&times;</button>
                </div>
                
                <div class="trade-modal__purchase-container">
                    <div class="trade-modal__purchase-item">
                    <img src="" class="trade-modal__purchase-image" id="cashItemImage">
                    <div class="trade-modal__purchase-details">
                        <h3 class="trade-modal__purchase-name" id="cashItemName"></h3>
                        <div class="trade-modal__purchase-price">$<span id="cashItemPrice"></span></div>
                        <div class="trade-modal__purchase-seller">Seller: <span id="cashItemSeller"></span></div>
                    </div>
                    </div>
                    
                    <div class="trade-modal__purchase-options">
                    <div class="trade-modal__purchase-option">
                        <h4 class="trade-modal__option-title">Buy Now</h4>
                        <p class="trade-modal__option-desc">Purchase immediately at listed price</p>
                        <button class="trade-modal__btn trade-modal__btn--buy" id="buyNowBtn">
                        Buy Now ($<span id="buyNowPrice">0.00</span>)
                        </button>
                        <div class="trade-modal__balance-check">
                        Your balance: $<span id="currentBalance">0.00</span>
                        <span class="trade-modal__balance-status" id="balanceStatus"></span>
                        </div>
                    </div>
                    
                    <div class="trade-modal__purchase-option">
                        <h4 class="trade-modal__option-title">Make Offer</h4>
                        <p class="trade-modal__option-desc">Suggest your own price</p>
                        <div class="trade-modal__offer-form">
                        <input type="number" class="trade-modal__offer-input" id="offerAmount" placeholder="Your offer">
                        <button class="trade-modal__btn trade-modal__btn--offer" id="sendOfferBtn">Send Offer</button>
                        </div>
                    </div>
                    </div>
                </div>
                </div>
            </div>
        </div>




