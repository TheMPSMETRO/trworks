                    </ul>
                </div>
            </div>
            
            <div class="copyright">
                &copy; 2023 TradeWorks. Not affiliated with Valve or Steam. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="/views/tradingpage/trading.js"></script>

</body>
</html>